<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WB Card Generator v1.5 (AI + Template)</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
<style>
body { background-color: #1e1e1e; color: white; font-family: Arial, sans-serif; display: flex; height: 100vh; margin: 0; }
.sidebar { width: 300px; background-color: #2d2d2d; padding: 20px; display: flex; flex-direction: column; gap: 15px; border-right: 1px solid #444; overflow-y: auto; }
button { padding: 12px; background: #6b21a8; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: bold; transition: 0.2s; }
button:hover { background: #9333ea; }
.ai-btn { background: #d946ef; margin-top: 10px; border: 2px solid #ff79c6; }
.ai-btn:hover { background: #e879f9; }
.control-group { background: #3b3b3b; padding: 15px; border-radius: 8px; display: flex; flex-direction: column; gap: 10px; }
.canvas-container-wrapper { flex-grow: 1; display: flex; justify-content: center; align-items: center; background: #121212; }
canvas { box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
input[type=text], input[type=color] { padding: 8px; border-radius: 4px; border: none; width: 100%; box-sizing: border-box; }
small { font-size: 10px; color: #aaa; }
</style>
</head>
<body>

<div class="sidebar">
    <h2>🛠 WBCreator</h2>

    <div class="control-group">
        <label>🎨 Цвет фона:</label>
        <input type="color" id="bgColorPicker" value="#f0f0f0">
    </div>

    <div class="control-group">
        <label>🔑 API ключ remove.bg:</label>
        <input type="text" id="apiKeyInput" placeholder="Вставьте сюда ваш ключ">
        <small>Получить ключ: remove.bg → Profile → API Key → Create new key</small>
    </div>

    <button onclick="document.getElementById('imageUpload').click()">📷 1. Загрузить товар</button>
    <input type="file" id="imageUpload" accept="image/*" style="display:none">

    <button id="removeBgBtn" class="ai-btn">✂️ 2. Удалить фон (AI)</button>
    <button id="addShapeBtn">🟩 3. Добавить плашку</button>
    <button id="addTextBtn">✍️ 4. Добавить текст</button>
    <button id="bringToFrontBtn" style="background: #475569;">🔼 Вынести на передний план</button>
    <button id="applyTemplateBtn" style="background: #10b981;">📐 Применить шаблон</button>
    <button id="downloadBtn" style="margin-top: auto; background: #00c6ff; color: #000;">⬇️ Скачать (HD)</button>
</div>

<div class="canvas-container-wrapper">
    <canvas id="mainCanvas" width="450" height="600"></canvas>
</div>

<script>
const canvas = new fabric.Canvas('mainCanvas', { backgroundColor: '#f0f0f0' });

// --- Смена цвета фона ---
document.getElementById('bgColorPicker').addEventListener('input', e => {
    canvas.setBackgroundColor(e.target.value, canvas.renderAll.bind(canvas));
});

// --- Сохранение API ключа в localStorage ---
const apiInput = document.getElementById('apiKeyInput');
apiInput.value = localStorage.getItem('removeBgApiKey') || '';
apiInput.addEventListener('input', () => {
    localStorage.setItem('removeBgApiKey', apiInput.value.trim());
});

// --- Загрузка изображения ---
document.getElementById('imageUpload').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(event) {
        // ИСПРАВЛЕНИЕ: добавлен crossOrigin для корректного toDataURL при экспорте
        fabric.Image.fromURL(event.target.result, function(img) {
            img.scaleToWidth(350);
            img.set({ left: 50, top: 150 });
            canvas.add(img);
            canvas.setActiveObject(img);
            canvas.renderAll();
        }, { crossOrigin: 'anonymous' });
    };
    reader.readAsDataURL(file);
    // Сброс input, чтобы можно было загрузить тот же файл повторно
    this.value = '';
});

// --- Добавление плашки ---
document.getElementById('addShapeBtn').addEventListener('click', () => {
    const rect = new fabric.Rect({
        left: 30, top: 50,
        fill: '#ffc107',
        width: 250, height: 60,
        rx: 15, ry: 15
    });
    canvas.add(rect);
    canvas.setActiveObject(rect);
});

// --- Добавление текста ---
document.getElementById('addTextBtn').addEventListener('click', () => {
    const text = new fabric.IText('ХИТ ПРОДАЖ', {
        left: 50, top: 60,
        fontFamily: 'Arial Black',
        fontSize: 26,
        fontWeight: 'bold',
        fill: '#1e1e1e'
    });
    canvas.add(text);
    canvas.setActiveObject(text);
});

// --- Вынести на передний план ---
document.getElementById('bringToFrontBtn').addEventListener('click', () => {
    const obj = canvas.getActiveObject();
    if (obj) canvas.bringToFront(obj);
});

// --- Скачать ---
document.getElementById('downloadBtn').addEventListener('click', () => {
    const link = document.createElement('a');
    link.href = canvas.toDataURL({ format: 'jpeg', quality: 0.9, multiplier: 2 });
    link.download = 'wb-ready-card.jpg';
    link.click();
});

// --- Удаление клавишей Delete / Backspace ---
// ИСПРАВЛЕНИЕ: добавлена проверка на null перед обращением к .isEditing
window.addEventListener('keydown', e => {
    if (e.key !== 'Delete' && e.key !== 'Backspace') return;
    const obj = canvas.getActiveObject();
    if (obj && !obj.isEditing) {
        canvas.remove(obj);
        canvas.renderAll();
    }
});

// --- Удаление фона через remove.bg ---
document.getElementById('removeBgBtn').addEventListener('click', async function() {
    const apiKey = apiInput.value.trim();
    const activeObject = canvas.getActiveObject();
    if (!activeObject || activeObject.type !== 'image') {
        alert('Выделите изображение товара!');
        return;
    }
    if (!apiKey) {
        alert('Вставьте API ключ от remove.bg!');
        return;
    }

    const btn = this;
    const originalText = btn.innerHTML;
    btn.innerHTML = '⏳ Обработка нейросетью...';
    btn.disabled = true;

    try {
        const base64Img = activeObject.toDataURL({ format: 'png' }).split(',')[1];
        const formData = new FormData();
        formData.append('image_file_b64', base64Img);
        formData.append('size', 'auto');

        const response = await fetch('https://api.remove.bg/v1.0/removebg', {
            method: 'POST',
            headers: { 'X-Api-Key': apiKey },
            body: formData
        });

        if (!response.ok) {
            const errText = await response.text();
            throw new Error(`Ошибка API: ${response.status} — ${errText}`);
        }

        const blob = await response.blob();
        const reader = new FileReader();
        reader.onloadend = function() {
            fabric.Image.fromURL(reader.result, function(newImg) {
                newImg.scaleToWidth(activeObject.getScaledWidth());
                newImg.set({ left: activeObject.left, top: activeObject.top });
                canvas.remove(activeObject);
                canvas.add(newImg);
                canvas.setActiveObject(newImg);
                canvas.renderAll();
            }, { crossOrigin: 'anonymous' });
        };
        reader.readAsDataURL(blob);

    } catch (error) {
        alert('Не удалось удалить фон. Проверьте интернет или API ключ.\n' + error.message);
        console.error(error);
    } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
});

// --- Применить шаблон ---
// ИСПРАВЛЕНИЕ: функция была полностью обрезана — восстановлена и дописана
document.getElementById('applyTemplateBtn').addEventListener('click', () => {
    const bgColor = document.getElementById('bgColorPicker').value;
    canvas.clear();
    canvas.setBackgroundColor(bgColor, canvas.renderAll.bind(canvas));

    // Верхняя плашка — заголовок
    const topRect = new fabric.Rect({
        left: 50, top: 40,
        fill: '#f59e0b',
        width: 350, height: 60,
        rx: 15, ry: 15,
        selectable: true
    });

    const topText = new fabric.IText('ХИТ ПРОДАЖ', {
        left: 90, top: 55,
        fontFamily: 'Arial Black',
        fontSize: 26,
        fontWeight: 'bold',
        fill: '#1e1e1e'
    });

    // Нижняя плашка — цена / CTA
    const bottomRect = new fabric.Rect({
        left: 50, top: 500,
        fill: '#6b21a8',
        width: 350, height: 60,
        rx: 15, ry: 15,
        selectable: true
    });

    const bottomText = new fabric.IText('ЗАКАЗАТЬ СЕЙЧАС', {
        left: 75, top: 515,
        fontFamily: 'Arial Black',
        fontSize: 22,
        fontWeight: 'bold',
        fill: '#ffffff'
    });

    // Подсказка по центру — куда добавить фото товара
    const hint = new fabric.IText('← загрузи фото товара сюда →', {
        left: 45, top: 270,
        fontFamily: 'Arial',
        fontSize: 16,
        fill: '#aaaaaa',
        fontStyle: 'italic',
        selectable: false
    });

    canvas.add(topRect, topText, bottomRect, bottomText, hint);
    canvas.renderAll();
});
</script>
</body>
</html>
